# Runtime provider configuration — copy to .env and fill in your values.
# NEVER commit .env; it is listed in .gitignore.

# Primary provider: Alibaba Cloud Model Studio International (Singapore)
MODEL_PROVIDER=qwen
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=sk-your-key-here
VISION_MODEL=qwen3.5-plus

# Fallback (lower cost/quota): same endpoint, flash model
# VISION_MODEL=qwen3.5-flash

# Alternative: standard OpenAI (comment out dashscope vars and use these)
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# VISION_MODEL=gpt-4o

# Alternative: Anthropic Claude
# MODEL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# VISION_MODEL=claude-sonnet-4-6
