# Runtime configuration — copy to .env and fill in your key.
# NEVER commit .env; it is listed in .gitignore.

# Provider: Alibaba Cloud Model Studio International (Singapore)
DASHSCOPE_API_KEY=sk-your-key-here

# Optional: override base URL (defaults to DashScope International)
# OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Optional: override model (default: qwen3.5-plus; budget: qwen3.5-flash)
# VISION_MODEL=qwen3.5-plus
