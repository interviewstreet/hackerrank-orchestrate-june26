# Runtime configuration — copy to .env and fill in your key.
# NEVER commit .env; it is listed in .gitignore.

# Alibaba Cloud DashScope API key.
# Create one at: https://dashscope-intl.aliyuncs.com/ (International / US zone)
# Keys from the China-mainland console will not work with the US endpoint below.
DASHSCOPE_API_KEY=sk-your-key-here

# DashScope US endpoint (OpenAI-compatible).
# Must match the region where your key was created.
#   US/International: https://dashscope-us.aliyuncs.com/compatible-mode/v1
#   China-mainland:   https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# Optional: override model (default: qwen3.5-plus; budget alternative: qwen3.5-flash)
# VISION_MODEL=qwen3.5-plus
